@page
@model CustomerManagement.Web.Views.Customers.IndexModel
@{
    ViewData["Title"] = "Customers";

}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Customers</h1>
    <button class="btn btn-primary" data-bind="click: newCustomer">+ New customer</button>
</div>

<div class="alert alert-danger" data-bind="visible: errorMessage, text: errorMessage"
    style="display:none"></div>

<div class="text-muted" data-bind="visible: isLoading" style="display:none">Loading...</div>

<div class="card" data-bind="visible: isLoading()" style="display:none">
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Code</th><th>Name</th><th>Type</th>
                    <th>Date of birth</th><th>Status</th><th class="text-end">Action</th>
                </tr>
            </thead>
            <tbody data-bind="fireach: customers">
                <tr>
                    <td data-bind="text: customerCode"></td>
                    <td data-bind="text: customerName"></td>
                    <td data-bind="text: customerType"></td>
                    <td data-bind="text: $root.formatDate(dateOfBirth)"></td>
                    <td>
                        <span class="badge"
                              data-bind="text: isActive ? 'Active' : 'Inactive',
                        css: isActive ? 'text-bg-success' : 'text-bg-secondary'"></span>
                    </td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-secondary"
                                data-bind="click: $root.editCustomer">
                            Edit
                        </button>
                        <button class="btn btn-sm btn-outline-danger"
                                data-bind="click: $root.deleteCustomer">
                            Delete
                        </button>
                    </td>

                </tr>
            </tbody>
        </table>
    </div>
    <div class="card-body text-muted"
         data-bind="visible: customers().length === 0" style="display:none">
        No customers yet.
    </div>
</div>

<div class="modal fade" id="customerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" data-bind="with: editing">
            <div class="modal-header">
                <h5 class="modal-title"
                    data-bind="text: $root.isEdit() ? 'Edit customer' : 'New customer'"></h5>
                <button type="button" class="btn-close" data-bind="click: $root.closeModal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Customer name *</label>
                    <input type="text" class="form-control"
                           data-bind="value: customerName, valueUpdate: 'input',
                    css: { 'is-invalid': $root.errors().customerName }" />
                    <div class="invalid-feedback" data-bind="text: $root.errors().customerName"></div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Customer type *</label>
                    <select class="form-select"
                            data-bind="value: customerType, options: $root.customerTypes"></select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Date of birth *</label>
                    <input type="date" class="form-control"
                           data-bind="value: dateOfBirth,
                    css: { 'is-invalid': $root.errors().dateOfBirth }" />
                    <div class="invalid-feedback" data-bind="text: $root.errors().dateOfBirth"></div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Address</label>
                    <textarea class="form-control" rows="2" data-bind="value: address"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" class="form-control"
                           data-bind="value: email, css: { 'is-invalid': $root.errors().email }" />
                    <div class="invalid-feedback" data-bind="text: $root.errors().email"></div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Phone number</label>
                    <input type="text" class="form-control" data-bind="value: phoneNumber" />
                </div>
                <div class="form-check" data-bind="visible: $root.isEdit">
                    <input class="form-check-input" type="checkbox" id="isActive"
                           data-bind="checked: isActive" />
                    <label class="form-check-label" for="isActive">Active</label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light"
                        data-bind="click: $root.closeModal">
                    Cancel
                </button>
                <button type="button" class="btn btn-primary"
                        data-bind="click: $root.saveCustomer, disable: $root.isSaving">
                    <span data-bind="text: $root.isSaving() ? 'Saving…' : 'Save'"></span>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/customers.js" asp-append-version="true"></script>
}